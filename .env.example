# ---- Docker Compose 统一配置 ----

# 对外端口号，容器内部端口保持默认值。
# MySQL / Redis 默认不对宿主机暴露端口。
WEB_PUBLIC_PORT=3000
SERVER_PUBLIC_PORT=18080

# Server
SERVER_PORT=8080
JWT_SECRET='ecohub_2026!local@dev_secret$001'

# MySQL
MYSQL_ROOT_PASSWORD=ecohub
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=eco
MYSQL_PASSWORD=ecohub
MYSQL_DBNAME=eco

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ecohub
REDIS_DB=0
