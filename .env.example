# Bracket Docker 部署环境变量配置
# 复制此文件为 .env 并修改为实际值
# cp .env.example .env

# ---- 服务端口 ----
SERVER_PORT=3601

# ---- 前端开发端口（可选）----
# 仅供 ./run-web.sh 本地开发使用，默认 3000
WEB_PORT=3000

JWT_SECRET=change_me_to_a_long_random_string

# ---- 前端 API 入口（可选）----
# 本地开发默认使用 http://127.0.0.1:$SERVER_PORT
# Docker / 容器网络场景建议显式设置，例如 http://server:3601
# API_URL=http://127.0.0.1:3601

# ---- MySQL 配置 ----
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=film
MYSQL_PASSWORD=your_mysql_password
MYSQL_DBNAME=FilmSite

# ---- Redis 配置 ----
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
