# ---- 服务端口 ----
PORT=8080

# ---- JWT ----
JWT_SECRET=change_me_to_a_long_random_string

# ---- MySQL 配置 ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=film
MYSQL_PASSWORD=your_mysql_password
MYSQL_DBNAME=FilmSite

# ---- Redis 配置 ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# ---- 开发模式（谨慎开启）----
# ENV=dev
# IS_DEV_MODE=true
